class Bank:
    def __init__(self):
        self.balance = 0

    def deposit(self):
        amt = float(input("Enter deposit amount: "))
        self.balance += amt

    def withdraw(self):
        amt = float(input("Enter withdrawal amount: "))
        if amt <= self.balance:
            self.balance -= amt
        else:
            print("Insufficient funds")

    def show_balance(self):
        print("Balance:", self.balance)

b = Bank()

while True:
    print("1.Deposit 2.Withdraw 3.Show 4.Exit")
    ch = int(input("Choice: "))
    if ch == 1:
        b.deposit()
    elif ch == 2:
        b.withdraw()
    elif ch == 3:
        b.show_balance()
    else:
        break
